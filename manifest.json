{
  "manifest_version": 3,
  "name": "Mastir",
  "version": "1.0",
  "description": "Conceals people in images using person segmentation",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mastir Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "exclude_matches": [
        "https://builderhub.corp.amazon.com/*",
        "https://*.amazon.dev/*",
        "https://code.amazon.com/*",
        "https://corp.amazon.com/*",
        "https://t.corp.amazon.com/*",
        "https://sushi.amazon.com/*",
        "https://build.amazon.com/*",
        "https://amazon.sharepoint.com/*",
        "https://*.aws.amazon.com/*",
        "https://w.amazon.com/*",
        "https://tod.amazon.com/*",
        "https://loop.cloud.microsoft/*",
        "https://jira.audible.com/*",
        "https://meetings.amazon.com/*",
        "https://wd12.myworkday.com/*",
        "https://*.adp.com/*",
        "https://idp.federate.amazon.com/*",
        "https://idp-us-east-1.federate.amazon.com/*",
        "https://midway.amazon.com/*",
        "https://*.midway-auth.amazon.com/*"
      ]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "exclude_matches": [
        "https://builderhub.corp.amazon.com/*",
        "https://*.amazon.dev/*",
        "https://code.amazon.com/*",
        "https://corp.amazon.com/*",
        "https://t.corp.amazon.com/*",
        "https://sushi.amazon.com/*",
        "https://build.amazon.com/*",
        "https://amazon.sharepoint.com/*",
        "https://*.aws.amazon.com/*",
        "https://w.amazon.com/*",
        "https://tod.amazon.com/*",
        "https://loop.cloud.microsoft/*",
        "https://jira.audible.com/*",
        "https://meetings.amazon.com/*",
        "https://wd12.myworkday.com/*",
        "https://*.adp.com/*",
        "https://idp.federate.amazon.com/*",
        "https://idp-us-east-1.federate.amazon.com/*",
        "https://midway.amazon.com/*",
        "https://*.midway-auth.amazon.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["selfie_multiclass_256x256.tflite", "vision_bundle.mjs", "wasm/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
