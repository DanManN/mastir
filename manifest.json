{
  "manifest_version": 3,
  "name": "Mastir",
  "version": "1.0",
  "description": "Conceals people in images using person segmentation",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mastir Settings"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "exclude_matches": [
        "https://*.midway-auth.amazon.com/*"
      ]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "exclude_matches": [
        "https://*.midway-auth.amazon.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["selfie_multiclass_256x256.tflite", "vision_bundle.mjs", "wasm/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
